# CopilotKit runtime URL (path of the backend AG-UI endpoint).
VITE_COPILOTKIT_RUNTIME_URL=/api/v1/copilotkit

# Show CopilotKit tool-call cards in the chat (navigate_to, etc.).
# true  → cards visible (recommended in dev for debugging)
# false → cards hidden (recommended in prod)
# unset → defaults to true in `bun dev`, false in `bun build`
VITE_SHOW_TOOL_CALLS=true
