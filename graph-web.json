{
  "version": "1",
  "name": "Project Hannibal — AI Tutor",
  "python": {
    "project_root": "backend",
    "venv": "backend/.venv"
  },
  "env_file": ".env",
  "required_env": ["LLM_PROVIDER"],
  "redact_env": ["*_KEY", "*_SECRET", "*_PASSWORD", "DATABASE_URL", "MONGO_URL", "SECRET_KEY"],
  "graphs": [
    {
      "id": "ai_tutor",
      "title": "AI Tutor",
      "entrypoint": "app/agent/ai_tutor/graph.py:build_graph",
      "kind": "factory",
      "checkpointer": "reuse",
      "undeclared_call_policy": "allow",
      "state": {
        "messages_key": "messages",
        "fields": [
          { "name": "user_memory", "type": "string",  "default": "",   "editable": true,  "seed": true },
          { "name": "course_id",   "type": "integer", "default": null, "editable": true,  "seed": true, "nullable": true },
          { "name": "course_info", "type": "string",  "default": null, "editable": true,  "seed": false, "nullable": true },
          { "name": "lesson_id",   "type": "integer", "default": null, "editable": true,  "seed": true, "nullable": true },
          { "name": "lesson_info", "type": "string",  "default": null, "editable": false, "seed": false, "nullable": true },
          { "name": "lesson_name", "type": "string",  "default": null, "editable": false, "seed": false, "nullable": true }
        ]
      },
      "context": [
        {
          "name": "user_id",
          "type": "integer",
          "title": "User ID",
          "default": 1,
          "editable": true,
          "inject": [
            { "target": "configurable", "key": "user_id" },
            { "target": "contextvar", "import": "app.agent.ai_tutor.state:active_user_id" }
          ]
        },
        {
          "name": "ck_context",
          "type": "json",
          "title": "Frontend context (CopilotKit)",
          "default": [
            { "description": "Current course", "value": { "courseId": 101 } },
            { "description": "Current lesson", "value": { "lessonId": 5 } }
          ],
          "editable": true,
          "inject": [
            { "target": "contextvar", "import": "app.agent.ai_tutor.state:active_ck_context" }
          ]
        }
      ],
      "tools": [
        {
          "name": "get_user_profile",
          "import": "app.agent.tools.user_tools:get_user_profile",
          "signature": [{ "name": "email", "type": "string" }],
          "returns": "string",
          "description": "Look up a registered user's profile by their email address.",
          "mock": {
            "mode": "arg_matched",
            "default": "User profile — id: 1, email: demo@example.com, provider: google, member since: 2024-01-01",
            "matches": [
              {
                "when": { "email": "alice@example.com" },
                "return": "User profile — id: 7, email: alice@example.com, provider: google, member since: 2023-05-02"
              }
            ]
          }
        },
        {
          "name": "recommend_course",
          "import": "app.agent.tools.course_tools:recommend_course",
          "signature": [
            { "name": "topic", "type": "string" },
            { "name": "level", "type": "integer" }
          ],
          "returns": "string",
          "description": "Recommend a course when the user asks about a topic outside the scope of their current lesson. The level is supplied by the recommend node from get_level(), not the LLM.",
          "mock": {
            "mode": "arg_matched",
            "default": "Recommended course for 'that topic' (level 0): Foundations of System Design. That question is outside your current lesson — this course covers it.",
            "matches": [
              {
                "when": { "level": 1 },
                "return": "Recommended course for 'that topic' (level 1): Designing Scalable Web Services. That question is outside your current lesson — this course covers it."
              },
              {
                "when": { "level": 2 },
                "return": "Recommended course for 'that topic' (level 2): Distributed Systems Deep Dive. That question is outside your current lesson — this course covers it."
              }
            ]
          }
        }
      ],
      "external_mocks": [
        {
          "id": "user_memory",
          "patch": "app.agent.ai_tutor.nodes.tutor.build_user_memory",
          "mode": "return",
          "is_async": true,
          "description": "Mocked — Beanie requires init_beanie() which only runs inside FastAPI startup",
          "return": "Role: student"
        }
      ]
    }
  ],
  "ui": {
    "default_graph": "ai_tutor",
    "theme": "graphite"
  }
}
